# CycleBubble ignore rules

# Academic papers should not be pushed to GitHub
cyclebubble_literature/papers/
*.pdf

# Local / temporary files
.runlogs/
.uploads/
*.zip
*.tmp
*.log
*.bak
*_b64_*.txt

# Dependencies and build outputs
node_modules/
dist/
build/

# Python virtual environment
venv/
.venv/
env/

# SQLite database (local dev only)
*.db
*.sqlite
*.sqlite3

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# System files
.DS_Store
Thumbs.db

# Local verification screenshots (not part of repo)
screenshot_*.jpeg
screenshot_*.png

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local
deploy/.env
