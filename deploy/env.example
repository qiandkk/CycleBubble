# CycleBubble 部署环境变量模板
# 复制为 .env 并填入真实值（.env 必须加入 .gitignore）
# 注意：deploy 脚本会把 .env 复制到 /var/www/app/.env 并 chmod 600。
# 密钥通过 systemd EnvironmentFile 读取，service 文件本身不再含密钥。
# ================================================================

# === 必填：用户 JWT 签名密钥 ===
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(48))"
# ⚠️ 不要使用任何默认值或弱密钥
CB_JWT_SECRET=<YOUR_RANDOM_SECRET_AT_LEAST_32_CHARS>

# === 必填：管理员 JWT 签名密钥（与用户密钥必须不同！）===
# 用途：签 admin 后台登录的 token。
# 设计原则：admin 密钥独立，泄露互不影响；不允许从 CB_JWT_SECRET 自动派生。
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(48))"
CB_ADMIN_JWT_SECRET=<YOUR_RANDOM_ADMIN_JWT_SECRET_AT_LEAST_32_CHARS>

# === 必填：管理员密码（admin 后台登录用）===
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(48))"
# ⚠️ 不要使用默认值或弱密码
CB_ADMIN_PASSWORD=<YOUR_RANDOM_ADMIN_PASSWORD_AT_LEAST_16_CHARS>

# === 必填：数据库路径 ===
CB_DATABASE_URL=sqlite:////var/www/app/cyclebubble.db
# 演示库路径会自动推导为 cyclebubble_demo.db，不需要手动设置

# === 必填：GitHub Webhook 签名密钥 ===
# 生成命令：openssl rand -hex 32
# ⚠️ 必须和 GitHub 仓库 Settings → Webhooks → Secret 完全一致
CB_GITHUB_WEBHOOK_SECRET=<YOUR_RANDOM_64_HEX_CHARS>

# === 选填：API 文档（/docs /redoc /openapi.json）开关 ===
# 默认 false（关闭）。生产环境强烈建议保持关闭——Swagger UI 会把整个
# API schema（包括 admin 端点）暴露给公网，且自带 "Try it out"。
# 仅在本地开发时设为 true。
# CB_API_DOCS_ENABLED=false

# === 选填：默认 AI 提供商 ===
# 如果不设置，使用 config.py 默认值（minimax）
# CB_AI_DEFAULT_PROVIDER=minimax

# === 选填：监听端口（默认 8000）===
# CB_API_PORT=8000

# === 选填：CORS 允许的来源 ===
# 一般不用设置，config.py 已经包含常见来源（localhost、服务器 IP、GitHub Pages）
# CB_CORS_ORIGINS=http://your-domain.com,https://your-domain.com
