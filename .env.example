# CycleBubble 后端环境变量模板
# 复制为 .env（gitignored）后填入实际值，本地启动 uvicorn 前请先 source 或由 dotenv 工具加载。

# ===== 必填 =====
# JWT 签名密钥。生产环境请用强随机值，例如：
#   openssl rand -hex 32
# 缺失时后端启动会直接报错，不会以不安全默认密钥兜底。
CB_JWT_SECRET=replace-me-with-a-long-random-string

# ===== 可选 =====
# DeepSeek API Key。缺失时 backend/ai_agent.py 走本地回退抽取逻辑。
# CB_DEEPSEEK_API_KEY=sk-...

# CORS 允许的 origin，CSV 形式。留空则使用 backend/config.py 中的默认值
# （覆盖本地常用端口 + Render 前端 + GitHub Pages）。
# 生产部署建议至少包含实际对外的前端域名，例如：
# CB_CORS_ORIGINS=https://qiandkk.github.io,https://your-custom-domain.com

# 数据库 URL。默认 sqlite:///./cyclebubble.db，演示用 SQLite 即可。
# 生产化阶段可平滑切换到 Postgres：CB_DATABASE_URL=postgresql://user:pwd@host/db
# CB_DATABASE_URL=sqlite:///./cyclebubble.db
